# Copy to .env (never commit .env). See RENDER.md for production.
# On Render, RENDER=true is set automatically (used for CORS + diagnostics).
#
# ENVIRONMENT=development
# API_KEY=
#
# CORS: on Render, CORS_WILDCARD defaults to on → Access-Control-Allow-Origin: *
# Set CORS_WILDCARD=0 to use ALLOWED_ORIGINS + *.onrender.com regex instead.
# ALLOWED_ORIGINS=http://localhost:5173
# ALLOW_ORIGIN_REGEX=0
#
# OpenRouter HTTP read timeout (seconds) — raise if coach report times out:
# OPEN_ROUTER_TIMEOUT_S=195
# OPEN_ROUTER_TIMEOUT_MAX_S=210
#
# OpenRouter (optional — AI coach text)
# OPEN_ROUTER_API_KEY=
# OPEN_ROUTER_PROFILE=balanced
# OPEN_ROUTER_MODEL=google/gemini-2.5-flash
# OPEN_ROUTER_BUDGET=0
# OPEN_ROUTER_MAX_TOKENS=900
# OPEN_ROUTER_MAX_TOKENS_CAP=1536
# OPEN_ROUTER_INCLUDE_ANALYTICS=1
# OPEN_ROUTER_TIMEOUT_S=75
# OPEN_ROUTER_TIMEOUT_MAX_S=90
#
# Data (e.g. Render Disk mount path)
# DATA_STORE_DIR=
# PERSIST_DATA=1
