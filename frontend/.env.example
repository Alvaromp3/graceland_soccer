# Vite: copy to .env.local for local overrides (never commit secrets).
#
# Local dev: leave unset to use the Vite proxy to http://localhost:8000
# Production build: set to your API origin (no path, no trailing slash)
# VITE_API_BASE_URL=https://your-backend.onrender.com
#
# Only if the API uses API_KEY middleware (value is visible in the JS bundle)
# VITE_API_KEY=
